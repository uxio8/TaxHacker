model File {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId    String   @map("organization_id") @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  filename          String
  path              String
  mimetype          String
  metadata          Json?
  isReviewed        Boolean  @default(false) @map("is_reviewed")
  isSplitted        Boolean  @default(false) @map("is_splitted")
  cachedParseResult Json?    @map("cached_parse_result")
  createdAt         DateTime @default(now()) @map("created_at")
  analysisJobs      AnalysisJob[]
  fiscalFilingReceiptDossiers FiscalFilingDossier[] @relation("FiscalFilingDossierReceipt")

  @@index([organizationId])
  @@index([organizationId, isReviewed, createdAt])
  @@map("files")
}

model Transaction {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId        String    @map("organization_id") @db.Uuid
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String?
  description           String?
  merchant              String?
  total                 Int?
  currencyCode          String?   @map("currency_code")
  convertedTotal        Int?      @map("converted_total")
  convertedCurrencyCode String?   @map("converted_currency_code")
  type                  String?   @default("expense")
  items                 Json      @default("[]")
  note                  String?
  files                 Json      @default("[]")
  extra                 Json?
  category              Category? @relation(fields: [categoryCode, organizationId], references: [code, organizationId])
  categoryCode          String?   @map("category_code")
  project               Project?  @relation(fields: [projectCode, organizationId], references: [code, organizationId])
  projectCode           String?   @map("project_code")
  issuedAt              DateTime? @map("issued_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  text                  String?
  fiscalDocument        TransactionFiscal?

  @@unique([id, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, projectCode])
  @@index([organizationId, categoryCode])
  @@index([organizationId, issuedAt])
  @@index([projectCode])
  @@index([categoryCode])
  @@index([issuedAt])
  @@index([name])
  @@index([merchant])
  @@index([total])
  @@map("transactions")
}

model TransactionFiscal {
  id                         String                   @id @map("fiscal_document_id")
  ownerScopeId               String                   @map("owner_scope_id") @db.Uuid
  ownerScope                 FiscalProfile            @relation(fields: [ownerScopeId], references: [id], onDelete: Cascade)
  sourceTransactionId        String                   @unique @map("source_transaction_id") @db.Uuid
  transaction                Transaction              @relation(fields: [sourceTransactionId], references: [id], onDelete: Cascade)
  documentKind               String                   @map("document_kind")
  direction                  String
  invoiceNumber              String?                  @map("invoice_number")
  invoiceSeries              String?                  @map("invoice_series")
  issueDate                  DateTime                 @map("issue_date") @db.Date
  operationDate              DateTime?                @map("operation_date") @db.Date
  paymentDate                DateTime?                @map("payment_date") @db.Date
  currencyCode               String                   @default("EUR") @map("currency_code")
  counterpartyId             String?                  @map("counterparty_id") @db.Uuid
  counterparty               Counterparty?            @relation(fields: [counterpartyId], references: [id], onDelete: Restrict)
  counterpartyRole           String                   @default("unknown") @map("counterparty_role")
  counterpartyName           String?                  @map("counterparty_name")
  counterpartyTaxId          String?                  @map("counterparty_tax_id")
  counterpartyCountryCode    String                   @default("ES") @map("counterparty_country_code")
  companyTaxId               String?                  @map("company_tax_id")
  reviewStatus               String                   @default("pending") @map("review_status")
  reviewReasons              Json                     @default("[]") @map("review_reasons")
  vatPeriodAssignment        Json?                    @map("vat_period_assignment")
  withholdingPeriodAssignment Json?                   @map("withholding_period_assignment")
  observedAmountCents        Int                      @default(0) @map("observed_amount_cents")
  totalNetCents              Int                      @default(0) @map("total_net_cents")
  totalVatCents              Int                      @default(0) @map("total_vat_cents")
  totalWithholdingCents      Int                      @default(0) @map("total_withholding_cents")
  totalGrossCents            Int                      @default(0) @map("total_gross_cents")
  totalPayableCents          Int                      @default(0) @map("total_payable_cents")
  sourceConfidence           String                   @default("manual") @map("source_confidence")
  notes                      String?
  createdAt                  DateTime                 @default(now()) @map("created_at")
  updatedAt                  DateTime                 @updatedAt @map("updated_at")
  auditEvents                FiscalAuditLog[]
  reviewRequests             FiscalReviewRequest[]
  lines                      TransactionFiscalLine[]

  @@unique([ownerScopeId, sourceTransactionId])
  @@index([ownerScopeId, reviewStatus, issueDate])
  @@index([counterpartyId])
  @@map("transaction_fiscals")
}

model TransactionFiscalLine {
  id                         String            @id @map("line_id")
  transactionFiscalId        String            @map("transaction_fiscal_id")
  transactionFiscal          TransactionFiscal @relation(fields: [transactionFiscalId], references: [id], onDelete: Cascade)
  lineNumber                 Int               @map("line_number")
  concept                    String
  baseAmountCents            Int               @default(0) @map("base_amount_cents")
  vatTreatment               String            @default("out_of_scope") @map("vat_treatment")
  vatRateBps                 Int               @default(0) @map("vat_rate_bps")
  vatAmountCents             Int               @default(0) @map("vat_amount_cents")
  withholdingApplicable      Boolean           @default(false) @map("withholding_applicable")
  withholdingRegime          String            @default("none") @map("withholding_regime")
  withholdingBaseCents       Int               @default(0) @map("withholding_base_cents")
  withholdingRateBps         Int               @default(0) @map("withholding_rate_bps")
  withholdingAmountCents     Int               @default(0) @map("withholding_amount_cents")
  deductibilityPercentBps    Int               @default(0) @map("deductibility_percent_bps")
  deductibilityReason        String            @default("not_applicable") @map("deductibility_reason")
  expenseFamily              String            @default("none") @map("expense_family")
  isReadyForVatBooks         Boolean           @default(false) @map("is_ready_for_vat_books")
  isReadyForWithholdingBooks Boolean           @default(false) @map("is_ready_for_withholding_books")
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @updatedAt @map("updated_at")

  @@unique([transactionFiscalId, lineNumber])
  @@index([transactionFiscalId, isReadyForVatBooks], map: "transaction_fiscal_lines_vat_ready_idx")
  @@index([transactionFiscalId, isReadyForWithholdingBooks], map: "transaction_fiscal_lines_withholding_ready_idx")
  @@map("transaction_fiscal_lines")
}


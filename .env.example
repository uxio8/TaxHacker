PORT=7331
SELF_HOSTED_MODE=false
SELF_HOSTED_ADMIN_TOKEN="replace-with-a-long-random-string"
DISABLE_SIGNUP=false

UPLOAD_PATH="./data/uploads"
DATABASE_URL="postgresql://user@localhost:5432/ledgerflow"

# Optional Pool Cloud integration. When the first three values are set,
# Pool Cloud appears in LLM settings and the analysis worker can use it.
POOL_CLOUD_URL=""
POOL_CLOUD_TOKEN=""
POOL_CLOUD_SLUG=""
POOL_CLOUD_CLIENT_INSTANCE_ID=""

# Direct providers are optional and can be mixed with Pool Cloud.
OPENAI_MODEL_NAME="gpt-4o-mini"
OPENAI_API_KEY=""  # "sk-..."

GOOGLE_MODEL_NAME="gemini-2.5-flash"
GOOGLE_API_KEY=""

MISTRAL_MODEL_NAME="mistral-medium-latest"
MISTRAL_API_KEY=""

# Auth Config
BETTER_AUTH_SECRET="random-secret-key"  # please use any long random string here

# Stripe Configuration
STRIPE_SECRET_KEY=""  # "sk_live_..." or "sk_test_..."
STRIPE_WEBHOOK_SECRET=""  # "whsec_..."
STRIPE_PRICE_ID_STARTER=""
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_ADDON_TAX=""
STRIPE_PRICE_ID_ADDON_AI_PLUS=""
STRIPE_PRICE_ID_ADDON_EXTRA_STORAGE=""
STRIPE_PRICE_ID_ADDON_EXTRA_USERS=""

# Resend Configuration (optional, use if you want to send emails)
RESEND_API_KEY=""  # "re_..."
RESEND_AUDIENCE_ID=""  # "aud_..."
RESEND_FROM_EMAIL="LedgerFlow <user@localhost>"

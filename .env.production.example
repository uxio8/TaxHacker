BASE_URL=https://ledgerflow.example.com
PORT=7331

SELF_HOSTED_MODE=true
SELF_HOSTED_ADMIN_TOKEN=replace-with-a-long-random-string
DISABLE_SIGNUP=true
BETTER_AUTH_SECRET=replace-with-a-long-random-string
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ADDON_TAX=
STRIPE_PRICE_ID_ADDON_AI_PLUS=
STRIPE_PRICE_ID_ADDON_EXTRA_STORAGE=
STRIPE_PRICE_ID_ADDON_EXTRA_USERS=

POSTGRES_DB=ledgerflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-string
DATABASE_URL=postgresql://postgres:replace-with-a-long-random-string@postgres:5432/ledgerflow?schema=public

# Optional preflight target for the managed PostgreSQL cutover check.
MANAGED_DATABASE_URL=

UPLOAD_PATH=/app/data/uploads
STORAGE_PROVIDER=local
ANALYSIS_WORKER_AUTOSTART=false

# Optional storage provider override. Keep UPLOAD_PATH even with S3 because the worker heartbeat
# and temporary runtime files still live under /app/data.
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=eu-west-1
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_SESSION_TOKEN=

# Optional environment-managed analysis providers.
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
GOOGLE_MODEL_NAME=gemini-2.5-flash
GOOGLE_API_KEY=
MISTRAL_MODEL_NAME=mistral-medium-latest
MISTRAL_API_KEY=
POOL_CLOUD_URL=
POOL_CLOUD_TOKEN=
POOL_CLOUD_SLUG=
POOL_CLOUD_CLIENT_INSTANCE_ID=
